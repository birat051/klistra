# Firebase client (public) — used by the browser for Google sign-in on `/login`
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Public site URL for canonical links, Open Graph, sitemap, and robots.txt (no trailing slash), e.g. https://klistra.example
NEXT_PUBLIC_SITE_URL=

# Firebase Admin — single-line JSON string of the service account (verify ID tokens, set session cookie)
# Example: {"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=
